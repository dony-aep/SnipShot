# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cs text diff=csharp
*.xaml text
*.xml text
*.json text
*.config text
*.md text

# Visual Studio Solution files
*.sln text eol=crlf
*.csproj text eol=crlf
*.vbproj text eol=crlf
*.vcxproj text eol=crlf
*.props text eol=crlf
*.filters text eol=crlf
*.pubxml text eol=crlf

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary

# Font files
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Binary files
*.dll binary
*.exe binary
*.pdb binary

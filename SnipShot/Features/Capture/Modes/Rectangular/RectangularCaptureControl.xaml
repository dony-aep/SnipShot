<?xml version="1.0" encoding="utf-8"?>
<base:CaptureModeBase
        x:Class="SnipShot.Features.Capture.Modes.Rectangular.RectangularCaptureControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:base="using:SnipShot.Features.Capture.Modes.Base"
        xmlns:shapes="using:SnipShot.Shared.Controls.Toolbars.Shapes"
        xmlns:drawing="using:SnipShot.Shared.Controls.Toolbars.Drawing"
        xmlns:common="using:SnipShot.Shared.Controls.Common"
        xmlns:emoji="using:SnipShot.Shared.Controls.Toolbars.Emoji"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

        <!-- 
        Nota: BackgroundImage y FullShade son manejados por ShadeOverlayWindow.
        Este control solo contiene el OverlayCanvas con la lógica de selección y anotaciones.
        -->

        <Grid x:Name="RootGrid"
                  PointerPressed="RootGrid_PointerPressed"
                  PointerMoved="RootGrid_PointerMoved"
                  PointerReleased="RootGrid_PointerReleased"
                  PointerCanceled="RootGrid_PointerCanceled"
                  KeyDown="RootGrid_KeyDown"
                  Background="Transparent">
                
                <!-- KeyboardAccelerator para Esc (funciona sin importar el foco) -->
                <Grid.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Escape" Invoked="EscapeAccelerator_Invoked"/>
                        <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="CaptureAccelerator_Invoked"/>
                        <KeyboardAccelerator Key="S" Modifiers="Control" Invoked="SaveAccelerator_Invoked"/>
                        <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="CopyAccelerator_Invoked"/>
                        <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="UndoAccelerator_Invoked"/>
                        <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="RedoAccelerator_Invoked"/>
                </Grid.KeyboardAccelerators>
                
                <Canvas x:Name="OverlayCanvas">
                        <!-- Shades de selección (ocultan área fuera de la selección) -->
                        <Rectangle x:Name="TopShade"
                                           Fill="#40000000"
                                           Visibility="Collapsed"/>
                        <Rectangle x:Name="BottomShade"
                                           Fill="#40000000"
                                           Visibility="Collapsed"/>
                        <Rectangle x:Name="LeftShade"
                                           Fill="#40000000"
                                           Visibility="Collapsed"/>
                        <Rectangle x:Name="RightShade"
                                           Fill="#40000000"
                                           Visibility="Collapsed"/>
                        
                        <!-- Borde de selección -->
                        <Border x:Name="SelectionBorder"
                                        Visibility="Collapsed"
                                        BorderBrush="White"
                                        BorderThickness="2"
                                        Background="#00FFFFFF"
                                        CornerRadius="2"/>
                        
                        <!-- Canvas para formas dibujadas -->
                        <Canvas x:Name="ShapesCanvas" IsHitTestVisible="True"/>

                        <!-- Canvas para handles de formas (gestionado por ShapeManipulationManager) -->
                        <Canvas x:Name="ShapeHandlesCanvas" IsHitTestVisible="True" Visibility="Collapsed"/>
                        
                        <!-- Resize Handles - Corner Handles (L-shaped) -->
                        <Path x:Name="HandleNW"
                              Visibility="Collapsed"
                              Width="20" Height="20"
                              Fill="White"
                              Tag="NW"
                              Data="M 0 0 L 20 0 L 20 4 L 4 4 L 4 20 L 0 20 Z"
                              PointerEntered="Handle_PointerEntered"
                              PointerExited="Handle_PointerExited"
                              PointerPressed="Handle_PointerPressed"
                              PointerMoved="Handle_PointerMoved"
                              PointerReleased="Handle_PointerReleased"
                              PointerCaptureLost="Handle_PointerCaptureLost"/>
                        <Path x:Name="HandleNE"
                              Visibility="Collapsed"
                              Width="20" Height="20"
                              Fill="White"
                              Tag="NE"
                              Data="M 0 0 L 20 0 L 20 20 L 16 20 L 16 4 L 0 4 Z"
                              PointerEntered="Handle_PointerEntered"
                              PointerExited="Handle_PointerExited"
                              PointerPressed="Handle_PointerPressed"
                              PointerMoved="Handle_PointerMoved"
                              PointerReleased="Handle_PointerReleased"
                              PointerCaptureLost="Handle_PointerCaptureLost"/>
                        <Path x:Name="HandleSE"
                              Visibility="Collapsed"
                              Width="20" Height="20"
                              Fill="White"
                              Tag="SE"
                              Data="M 20 0 L 20 20 L 0 20 L 0 16 L 16 16 L 16 0 Z"
                              PointerEntered="Handle_PointerEntered"
                              PointerExited="Handle_PointerExited"
                              PointerPressed="Handle_PointerPressed"
                              PointerMoved="Handle_PointerMoved"
                              PointerReleased="Handle_PointerReleased"
                              PointerCaptureLost="Handle_PointerCaptureLost"/>
                        <Path x:Name="HandleSW"
                              Visibility="Collapsed"
                              Width="20" Height="20"
                              Fill="White"
                              Tag="SW"
                              Data="M 0 0 L 4 0 L 4 16 L 20 16 L 20 20 L 0 20 Z"
                              PointerEntered="Handle_PointerEntered"
                              PointerExited="Handle_PointerExited"
                              PointerPressed="Handle_PointerPressed"
                              PointerMoved="Handle_PointerMoved"
                              PointerReleased="Handle_PointerReleased"
                              PointerCaptureLost="Handle_PointerCaptureLost"/>
                        
                        <!-- Edge Handles (pill-shaped) -->
                        <Rectangle x:Name="HandleN"
                                   Visibility="Collapsed"
                                   Width="32" Height="8"
                                   Fill="White"
                                   RadiusX="4" RadiusY="4"
                                   Tag="N"
                                   PointerEntered="Handle_PointerEntered"
                                   PointerExited="Handle_PointerExited"
                                   PointerPressed="Handle_PointerPressed"
                                   PointerMoved="Handle_PointerMoved"
                                   PointerReleased="Handle_PointerReleased"
                                   PointerCaptureLost="Handle_PointerCaptureLost"/>
                        <Rectangle x:Name="HandleE"
                                   Visibility="Collapsed"
                                   Width="8" Height="32"
                                   Fill="White"
                                   RadiusX="4" RadiusY="4"
                                   Tag="E"
                                   PointerEntered="Handle_PointerEntered"
                                   PointerExited="Handle_PointerExited"
                                   PointerPressed="Handle_PointerPressed"
                                   PointerMoved="Handle_PointerMoved"
                                   PointerReleased="Handle_PointerReleased"
                                   PointerCaptureLost="Handle_PointerCaptureLost"/>
                        <Rectangle x:Name="HandleS"
                                   Visibility="Collapsed"
                                   Width="32" Height="8"
                                   Fill="White"
                                   RadiusX="4" RadiusY="4"
                                   Tag="S"
                                   PointerEntered="Handle_PointerEntered"
                                   PointerExited="Handle_PointerExited"
                                   PointerPressed="Handle_PointerPressed"
                                   PointerMoved="Handle_PointerMoved"
                                   PointerReleased="Handle_PointerReleased"
                                   PointerCaptureLost="Handle_PointerCaptureLost"/>
                        <Rectangle x:Name="HandleW"
                                   Visibility="Collapsed"
                                   Width="8" Height="32"
                                   Fill="White"
                                   RadiusX="4" RadiusY="4"
                                   Tag="W"
                                   PointerEntered="Handle_PointerEntered"
                                   PointerExited="Handle_PointerExited"
                                   PointerPressed="Handle_PointerPressed"
                                   PointerMoved="Handle_PointerMoved"
                                   PointerReleased="Handle_PointerReleased"
                                   PointerCaptureLost="Handle_PointerCaptureLost"/>
                        
                        <!-- Coordinates Display -->
                        <Border x:Name="CoordinatesDisplay"
                                        Visibility="Collapsed"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Translation="0,0,32">
                                <Border.Shadow>
                                        <ThemeShadow/>
                                </Border.Shadow>
                                <Border.Background>
                                        <AcrylicBrush TintColor="#202020"
                                                              TintOpacity="0.8"
                                                              TintLuminosityOpacity="0.8"
                                                              FallbackColor="#CC202020"/>
                                </Border.Background>
                                <TextBlock x:Name="CoordinatesText"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   FontFamily="Segoe UI Variable Display"
                                                   Text="0 × 0 px"
                                                   TextAlignment="Center"/>
                        </Border>
                        
                        <!-- Floating Toolbar -->
                        <Border x:Name="FloatingToolbar"
                                        Visibility="Collapsed"
                                        CornerRadius="8"
                                        Padding="8"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                        UseLayoutRounding="True"
                                        Translation="0,0,32"
                                        PointerPressed="FloatingMenu_PointerPressed">
                                <Border.Shadow>
                                        <ThemeShadow/>
                                </Border.Shadow>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                        <SplitButton x:Name="ConfirmButton"
                                                        Click="ConfirmButton_Click"
                                                        Padding="10,6"
                                                        CornerRadius="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE722;" FontSize="14"/>
                                                        <TextBlock Text="Capturar" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <SplitButton.Flyout>
                                                        <MenuFlyout Placement="Top">
                                                                <MenuFlyoutItem Text="Capturar" Click="CaptureMenuItem_Click"
                                                                                KeyboardAcceleratorTextOverride="Ctrl+Enter">
                                                                        <MenuFlyoutItem.Icon>
                                                                                <FontIcon Glyph="&#xE722;"/>
                                                                        </MenuFlyoutItem.Icon>
                                                                </MenuFlyoutItem>
                                                                <MenuFlyoutItem Text="Guardar" Click="SaveMenuItem_Click"
                                                                                KeyboardAcceleratorTextOverride="Ctrl+S">
                                                                        <MenuFlyoutItem.Icon>
                                                                                <FontIcon Glyph="&#xE74E;"/>
                                                                        </MenuFlyoutItem.Icon>
                                                                </MenuFlyoutItem>
                                                                <MenuFlyoutItem Text="Copiar" Click="CopyMenuItem_Click"
                                                                                KeyboardAcceleratorTextOverride="Ctrl+C">
                                                                        <MenuFlyoutItem.Icon>
                                                                                <FontIcon Glyph="&#xE8C8;"/>
                                                                        </MenuFlyoutItem.Icon>
                                                                </MenuFlyoutItem>
                                                        </MenuFlyout>
                                                </SplitButton.Flyout>
                                        </SplitButton>
                                        
                                        <!-- Botón de Formas -->
                                        <Button x:Name="ShapesButton"
                                            Click="ShapesButton_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="10"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Formas">
                                            <FontIcon Glyph="&#xF158;" FontSize="16"/>
                                        </Button>
                                        
                                        <!-- Botón Ballpoint Pen -->
                                        <Button x:Name="BallpointPenButton"
                                            Click="BallpointPenButton_Click"
                                            RightTapped="BallpointPenButton_RightTapped"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="10"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Bolígrafo">
                                            <FontIcon x:Name="BallpointPenIcon" Glyph="&#xE76D;" FontSize="16"/>
                                        </Button>
                                        
                                        <!-- Botón Highlighter -->
                                        <Button x:Name="HighlighterButton"
                                            Click="HighlighterButton_Click"
                                            RightTapped="HighlighterButton_RightTapped"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="10"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Resaltador">
                                            <FontIcon x:Name="HighlighterIcon" Glyph="&#xE7E6;" FontSize="16"/>
                                        </Button>
                                        
                                        <!-- Boton Borrador -->
                                        <Button x:Name="EraserButton"
                                                Click="EraserButton_Click"
                                                RightTapped="EraserButton_RightTapped"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="10"
                                                CornerRadius="4"
                                                ToolTipService.ToolTip="Borrador">
                                            <FontIcon Glyph="&#xE75C;" FontSize="16"/>
                                        </Button>
                                        
                                        <!-- Botón Emoji -->
                                        <Button x:Name="EmojiButton"
                                            Click="EmojiButton_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="10"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Emoji">
                                            <FontIcon Glyph="&#xE76E;" FontSize="16"/>
                                        </Button>
                                        
                                        <!-- Botón Texto -->
                                        <Button x:Name="TextButton"
                                            Click="TextButton_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="10"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Texto">
                                            <FontIcon Glyph="&#xE8D2;" FontSize="16"/>
                                        </Button>
                                        
                                        <Border Width="1"
                                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                                        
                                        <!-- Botón Undo -->
                                        <Button x:Name="UndoButton"
                                                Click="UndoButton_Click"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="10"
                                                CornerRadius="4"
                                                IsEnabled="False"
                                                ToolTipService.ToolTip="Deshacer (Ctrl+Z)">
                                            <FontIcon Glyph="&#xE7A7;" FontSize="16"/>
                                        </Button>
                                        
                                        <!-- Botón Redo -->
                                        <Button x:Name="RedoButton"
                                                Click="RedoButton_Click"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="10"
                                                CornerRadius="4"
                                                IsEnabled="False"
                                                ToolTipService.ToolTip="Rehacer (Ctrl+Y)">
                                            <FontIcon Glyph="&#xE7A6;" FontSize="16"/>
                                        </Button>
                                        
                                        <Border Width="1"
                                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                                        
                                        <Button x:Name="CancelButton"
                                                        Click="CancelButton_Click"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="10"
                                                        CornerRadius="4"
                                                        ToolTipService.ToolTip="Descartar Captura (Esc)">
                                                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                        </Button>
                                </StackPanel>
                        </Border>
                        
                        <!-- Menú Flotante de Formas (usando UserControl reutilizable) -->
                        <Border x:Name="FloatingShapesToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <shapes:ShapesToolbarControl x:Name="FloatingShapesToolbarContent"
                                                           ShapeSelected="FloatingShapesToolbar_ShapeSelected"
                                                           FillButtonClicked="FloatingShapesToolbar_FillButtonClicked"
                                                           StyleButtonClicked="FloatingShapesToolbar_StyleButtonClicked"/>
                        </Border>

                        <!-- Menú Flotante de Estilo (usando UserControl reutilizable) -->
                        <Border x:Name="FloatingStyleToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <shapes:StyleToolbarControl x:Name="FloatingStyleToolbarContent"
                                                          ColorChanged="FloatingStyleToolbar_ColorChanged"
                                                          OpacityChanged="FloatingStyleToolbar_OpacityChanged"
                                                          ThicknessChanged="FloatingStyleToolbar_ThicknessChanged"/>
                        </Border>

                        <!-- Menú Flotante de Fill (usando UserControl reutilizable) -->
                        <Border x:Name="FloatingFillToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <shapes:FillToolbarControl x:Name="FloatingFillToolbarContent"
                                                         ColorChanged="FloatingFillToolbar_ColorChanged"
                                                         OpacityChanged="FloatingFillToolbar_OpacityChanged"/>
                        </Border>

                        <!-- Menú Flotante de Bolígrafo (usando UserControl reutilizable) -->
                        <Border x:Name="FloatingPenToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <drawing:PenToolbarControl x:Name="FloatingPenToolbarContent"
                                                        ColorChanged="FloatingPenToolbar_ColorChanged"
                                                        ThicknessChanged="FloatingPenToolbar_ThicknessChanged"/>
                        </Border>

                        <!-- Menú Flotante de Resaltador (usando UserControl reutilizable) -->
                        <Border x:Name="FloatingHighlighterToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <drawing:HighlighterToolbarControl x:Name="FloatingHighlighterToolbarContent"
                                                                ColorChanged="FloatingHighlighterToolbar_ColorChanged"
                                                                ThicknessChanged="FloatingHighlighterToolbar_ThicknessChanged"/>
                        </Border>
                        
                        <!-- Menú Flotante de Texto -->
                        <Border x:Name="FloatingTextToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <StackPanel Spacing="8">
                                <!-- Vista Previa del Texto -->
                                <Border x:Name="TextPreviewBorder"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        MinHeight="50"
                                        MaxHeight="100"
                                        HorizontalAlignment="Stretch">
                                    <Border x:Name="TextPreviewHighlightBorder"
                                            Background="Transparent"
                                            CornerRadius="2"
                                            Padding="4,2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="TextPreviewBlock"
                                                   Text="Texto de ejemplo"
                                                   FontFamily="Segoe UI"
                                                   FontSize="16"
                                                   Foreground="White"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="500"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Border>
                                
                                <!-- Controles de formato -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                <!-- Selector de Fuente -->
                                <ComboBox x:Name="FontFamilyComboBox"
                                          Width="140"
                                          Height="36"
                                          VerticalAlignment="Center"
                                          SelectionChanged="FontFamilyComboBox_SelectionChanged"
                                          ToolTipService.ToolTip="Fuente">
                                    <ComboBoxItem Content="Segoe UI" IsSelected="True"/>
                                    <ComboBoxItem Content="Arial"/>
                                    <ComboBoxItem Content="Times New Roman"/>
                                    <ComboBoxItem Content="Calibri"/>
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="Comic Sans MS"/>
                                    <ComboBoxItem Content="Georgia"/>
                                    <ComboBoxItem Content="Verdana"/>
                                    <ComboBoxItem Content="Tahoma"/>
                                </ComboBox>

                                <!-- Selector de Tamaño (Editable) -->
                                <ComboBox x:Name="FontSizeComboBox"
                                          IsEditable="True"
                                          Width="75"
                                          Height="36"
                                          VerticalAlignment="Center"
                                          Text="16"
                                          TextSubmitted="FontSizeComboBox_TextSubmitted"
                                          SelectionChanged="FontSizeComboBox_SelectionChanged"
                                          ToolTipService.ToolTip="Tamaño de fuente">
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="16" IsSelected="True"/>
                                    <ComboBoxItem Content="18"/>
                                    <ComboBoxItem Content="20"/>
                                    <ComboBoxItem Content="24"/>
                                    <ComboBoxItem Content="28"/>
                                    <ComboBoxItem Content="32"/>
                                    <ComboBoxItem Content="36"/>
                                    <ComboBoxItem Content="48"/>
                                    <ComboBoxItem Content="56"/>
                                    <ComboBoxItem Content="72"/>
                                </ComboBox>

                                <Border Width="1" 
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        Margin="4,6"/>

                                <!-- Estilos de texto -->
                                <ToggleButton x:Name="BoldToggle"
                                              Click="BoldToggle_Click"
                                              Width="36" Height="36"
                                              Padding="0"
                                              CornerRadius="4"
                                              ToolTipService.ToolTip="Negrita (Ctrl+B)">
                                    <FontIcon Glyph="&#xE8DD;" FontSize="14"/>
                                </ToggleButton>
                                <ToggleButton x:Name="ItalicToggle"
                                              Click="ItalicToggle_Click"
                                              Width="36" Height="36"
                                              Padding="0"
                                              CornerRadius="4"
                                              ToolTipService.ToolTip="Cursiva (Ctrl+I)">
                                    <FontIcon Glyph="&#xE8DB;" FontSize="14"/>
                                </ToggleButton>
                                <ToggleButton x:Name="UnderlineToggle"
                                              Click="UnderlineToggle_Click"
                                              Width="36" Height="36"
                                              Padding="0"
                                              CornerRadius="4"
                                              ToolTipService.ToolTip="Subrayado (Ctrl+U)">
                                    <FontIcon Glyph="&#xE8DC;" FontSize="14"/>
                                </ToggleButton>
                                <ToggleButton x:Name="StrikethroughToggle"
                                              Click="StrikethroughToggle_Click"
                                              Width="36" Height="36"
                                              Padding="0"
                                              CornerRadius="4"
                                              ToolTipService.ToolTip="Tachado">
                                    <FontIcon Glyph="&#xEDE0;" FontSize="14"/>
                                </ToggleButton>

                                <Border Width="1" 
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        Margin="4,6"/>

                                <!-- Botón Color de Texto -->
                                <Button x:Name="TextColorButton"
                                        Click="TextColorButton_Click"
                                        Width="36" Height="36"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        ToolTipService.ToolTip="Color del texto">
                                    <Grid>
                                        <FontIcon Glyph="&#xE8D3;" FontSize="14" Margin="0,-2,0,0"/>
                                        <Border x:Name="TextColorIndicator"
                                                Height="4"
                                                Width="16"
                                                Background="White"
                                                CornerRadius="1"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,0,4"/>
                                    </Grid>
                                </Button>

                                <!-- Botón Color de Resaltado -->
                                <Button x:Name="TextHighlightButton"
                                        Click="TextHighlightButton_Click"
                                        Width="36" Height="36"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        ToolTipService.ToolTip="Color de resaltado">
                                    <Grid>
                                        <FontIcon Glyph="&#xE7E6;" FontSize="14" Margin="0,-2,0,0"/>
                                        <Border x:Name="TextHighlightIndicator"
                                                Height="4"
                                                Width="16"
                                                Background="Transparent"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="1"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,0,4"/>
                                    </Grid>
                                </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Menú Flotante de Color de Texto -->
                        <Border x:Name="FloatingTextColorToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <common:ColorPaletteControl x:Name="TextColorPalette"
                                                          PaletteType="Text"
                                                          Title="Color del texto"
                                                          ColorSelected="TextColorPalette_ColorSelected"/>
                        </Border>

                        <!-- Menú Flotante de Color de Resaltado -->
                        <Border x:Name="FloatingTextHighlightToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <common:ColorPaletteControl x:Name="TextBackgroundColorPalette"
                                                          PaletteType="TextHighlight"
                                                          Title="Color de resaltado"
                                                          ColorSelected="TextBackgroundColorPalette_ColorSelected"/>
                        </Border>
                        
                        <!-- Menú Flotante de Emojis -->
                        <Border x:Name="FloatingEmojiToolbar"
                                Visibility="Collapsed"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                IsHitTestVisible="True"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <emoji:EmojiToolbarControl x:Name="FloatingEmojiToolbarContent"
                                                       EmojiSelected="FloatingEmojiToolbar_EmojiSelected"/>
                        </Border>
                        
                        <!-- Menú Flotante de Captura (por encima de todo) -->
                        <Border x:Name="CaptureFloatingMenu"
                                Visibility="Visible"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,8"
                                Translation="0,0,32"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                PointerPressed="FloatingMenu_PointerPressed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <!-- Menú desplegable de modos -->
                                <Button x:Name="CaptureModeButton"
                                       ToolTipService.ToolTip="Modo de captura"
                                       MinWidth="68" Height="34" Padding="10,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon x:Name="CaptureModeIcon" Glyph="&#xF407;" FontSize="16" Foreground="{ThemeResource OverlayTextBrush}"/>
                                        <FontIcon Glyph="&#xE70D;" FontSize="11" Foreground="{ThemeResource OverlayTextBrush}"/>
                                    </StackPanel>
                                    <Button.Flyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem Text="Captura Rectangular" 
                                                          Click="FloatingRectangular_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xF407;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            
                                            <MenuFlyoutItem Text="Captura de Ventana" 
                                                          Click="FloatingWindow_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xF7ED;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            
                                            <MenuFlyoutItem Text="Pantalla Completa" 
                                                          Click="FloatingFullScreen_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE9A6;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            
                                            <MenuFlyoutItem Text="Forma Libre" 
                                                          Click="FloatingFreeForm_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xF408;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                
                                <!-- Botón Color Picker -->
                                <Button x:Name="ColorPickerButton"
                                       Click="ColorPickerButton_Click"
                                       ToolTipService.ToolTip="Selector de Color"
                                       Width="34" Height="34" Padding="0">
                                    <FontIcon Glyph="&#xEF3C;" FontSize="16" Foreground="{ThemeResource OverlayTextBrush}"/>
                                </Button>
                                
                                <Border Width="1" 
                                       Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                       Margin="3,7"/>
                                
                                <!-- Botón cerrar -->
                                <Button x:Name="FloatingCloseButton"
                                       Click="FloatingClose_Click"
                                       ToolTipService.ToolTip="Cerrar"
                                       Width="34" Height="34" Padding="0">
                                    <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="{ThemeResource OverlayTextBrush}"/>
                                </Button>
                            </StackPanel>
                        </Border>
                </Canvas>
        </Grid>
</base:CaptureModeBase>

<?xml version="1.0" encoding="utf-8"?>
<base:CaptureModeBase
    x:Class="SnipShot.Features.Capture.Modes.ColorPicker.ColorPickerCaptureControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="using:SnipShot.Features.Capture.Modes.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" 
          Background="Transparent"
          PointerMoved="RootGrid_PointerMoved"
          PointerPressed="RootGrid_PointerPressed">
        
        <!-- KeyboardAccelerator para Esc (funciona sin importar el foco) -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="EscapeAccelerator_Invoked"/>
        </Grid.KeyboardAccelerators>
        
        <Canvas>
            <!-- Tooltip con información del color -->
            <Border x:Name="ColorTooltip"
                    BorderBrush="{ThemeResource OverlayBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,6"
                    Visibility="Collapsed"
                    Translation="0,0,32"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <TextBlock x:Name="ColorTooltipText"
                           Text="#FF0000"
                           FontSize="14"
                           FontWeight="SemiBold"
                           FontFamily="Consolas"
                           Foreground="{ThemeResource OverlayTextBrush}"/>
            </Border>
            
            <!-- Menú Flotante del Color Picker -->
            <Border x:Name="ColorPickerMenu"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Translation="0,0,32"
                    PointerPressed="ColorPickerMenu_PointerPressed"
                    PointerMoved="ColorPickerMenu_PointerMoved"
                    PointerReleased="ColorPickerMenu_PointerReleased"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                
                <StackPanel Spacing="12" MinWidth="280">
                    <!-- Muestra grande del color -->
                    <Border x:Name="ColorDisplay"
                            Height="60" 
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Border.Background>
                            <SolidColorBrush x:Name="ColorDisplayBrush" Color="Red"/>
                        </Border.Background>
                    </Border>
                    
                    <!-- Valor del color -->
                    <TextBlock x:Name="ColorValueText"
                               Text="#FF0000"
                               FontSize="18"
                               FontWeight="SemiBold"
                               FontFamily="Consolas"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource OverlayTextBrush}"/>
                    
                    <!-- Controles -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <!-- Volver al overlay anterior -->
                        <Button x:Name="BackButton"
                                Click="BackButton_Click"
                                ToolTipService.ToolTip="Volver"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,6"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                        </Button>
                        
                        <!-- Selector de formato -->
                        <ComboBox x:Name="FormatComboBox"
                                  SelectedIndex="0"
                                  MinWidth="160"
                                  SelectionChanged="Format_Changed">
                            <ComboBoxItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="HEX" Grid.Column="0"/>
                                    <TextBlock Text="#RRGGBB" Grid.Column="1" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="16,0,0,0"/>
                                </Grid>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="RGB" Grid.Column="0"/>
                                    <TextBlock Text="R, G, B" Grid.Column="1" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="16,0,0,0"/>
                                </Grid>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="HSL" Grid.Column="0"/>
                                    <TextBlock Text="H, S%, L%" Grid.Column="1" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="16,0,0,0"/>
                                </Grid>
                            </ComboBoxItem>
                        </ComboBox>
                        
                        <!-- Cerrar -->
                        <Button x:Name="CloseButton"
                                Click="Close_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,6"
                                CornerRadius="4"
                                ToolTipService.ToolTip="Cerrar (ESC)">
                            <FontIcon Glyph="&#xE711;" FontSize="16"/>
                        </Button>
                    </StackPanel>
                    
                    <!-- Instrucciones -->
                    <TextBlock Text="Haz clic para copiar el color"
                               FontSize="12"
                               Foreground="{ThemeResource OverlayTextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</base:CaptureModeBase>

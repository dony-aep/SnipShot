<?xml version="1.0" encoding="utf-8"?>
<base:CaptureModeBase
    x:Class="SnipShot.Features.Capture.Modes.FreeForm.FreeFormCaptureControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="using:SnipShot.Features.Capture.Modes.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Background="Transparent"
          PointerPressed="RootGrid_PointerPressed"
          PointerMoved="RootGrid_PointerMoved"
          PointerReleased="RootGrid_PointerReleased"
          PointerCanceled="RootGrid_PointerCanceled"
          KeyDown="RootGrid_KeyDown">

        <!-- KeyboardAccelerator para Esc (funciona sin importar el foco) -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="EscapeAccelerator_Invoked"/>
        </Grid.KeyboardAccelerators>

        <Canvas x:Name="DrawingCanvas">
            <!-- Shade invertido: cubre toda la pantalla excepto el área de selección -->
            <Path x:Name="InvertedShadePath"
                  Visibility="Collapsed"
                  Fill="#40000000"
                  IsHitTestVisible="False"/>
            
            <!-- Path de la selección (borde visible del área seleccionada) -->
            <Path x:Name="SelectionPath"
                  Visibility="Collapsed"
                  Stroke="{ThemeResource OverlayBorderBrush}"
                  StrokeThickness="2.5"
                  Fill="Transparent"
                  IsHitTestVisible="False"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"/>

            <Border x:Name="FloatingToolbar"
                    Visibility="Collapsed"
                    CornerRadius="8"
                    Padding="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Translation="0,0,32"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SplitButton x:Name="ConfirmButton"
                                 Click="ConfirmButton_Click"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,6"
                                 CornerRadius="4">
                        <TextBlock Text="Capturar"/>
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem Text="Capturar" Click="CaptureMenuItem_Click"
                                                KeyboardAcceleratorTextOverride="Ctrl+Enter">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE722;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Guardar" Click="SaveMenuItem_Click"
                                                KeyboardAcceleratorTextOverride="Ctrl+S">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74E;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Copiar" Click="CopyMenuItem_Click"
                                                KeyboardAcceleratorTextOverride="Ctrl+C">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8C8;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                    <Button x:Name="CancelButton"
                            Click="CancelButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,6"
                            CornerRadius="4"
                            ToolTipService.ToolTip="Cancelar (Esc)">
                        <FontIcon Glyph="&#xE711;" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Menú Flotante de Captura (por encima de todo) -->
            <Border x:Name="CaptureFloatingMenu"
                    Visibility="Visible"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8"
                    Translation="0,0,32"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <!-- Menú desplegable de modos -->
                    <Button x:Name="CaptureModeButton"
                           ToolTipService.ToolTip="Modo de captura"
                           MinWidth="68" Height="34" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="CaptureModeIcon" Glyph="&#xF408;" FontSize="16" Foreground="{ThemeResource OverlayTextBrush}"/>
                            <FontIcon Glyph="&#xE70D;" FontSize="11" Foreground="{ThemeResource OverlayTextBrush}"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem Text="Captura Rectangular" 
                                              Click="FloatingRectangular_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF407;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                
                                <MenuFlyoutItem Text="Captura de Ventana" 
                                              Click="FloatingWindow_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF7ED;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                
                                <MenuFlyoutItem Text="Pantalla Completa" 
                                              Click="FloatingFullScreen_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9A6;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                
                                <MenuFlyoutItem Text="Forma Libre" 
                                              Click="FloatingFreeForm_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF408;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    
                    <!-- Botón selector de color -->
                    <Button x:Name="ColorPickerButton"
                           Click="ColorPickerButton_Click"
                           ToolTipService.ToolTip="Selector de Color"
                           Width="34" Height="34" Padding="0">
                        <FontIcon Glyph="&#xEF3C;" FontSize="16" Foreground="{ThemeResource OverlayTextBrush}"/>
                    </Button>
                    
                    <Border Width="1" 
                           Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                           Margin="3,7"/>
                    
                    <!-- Botón cerrar -->
                    <Button x:Name="FloatingCloseButton"
                           Click="FloatingClose_Click"
                           ToolTipService.ToolTip="Cerrar (ESC)"
                           Width="34" Height="34" Padding="0">
                        <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="{ThemeResource OverlayTextBrush}"/>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Panel de información (posicionado en pantalla principal) -->
            <Border x:Name="InfoPanel"
                    CornerRadius="10"
                    Padding="14,10"
                    BorderThickness="1"
                    Visibility="Visible"
                    IsHitTestVisible="False"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#4064A9FF"/>
                </Border.BorderBrush>
                <StackPanel Spacing="4">
                    <TextBlock x:Name="InfoTitleText"
                               Text="Dibuja el área a capturar"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="InfoSubtitleText"
                               Text="Mantén presionado el botón izquierdo y traza la forma libre."
                               TextWrapping="Wrap"
                               MaxWidth="320"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"/>
                </StackPanel>
            </Border>
        </Canvas>

    </Grid>
</base:CaptureModeBase>

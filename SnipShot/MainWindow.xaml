<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SnipShot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnipShot"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:SnipShot.Views"
    xmlns:controls="using:SnipShot.Features.Editor"
    xmlns:drawing="using:SnipShot.Shared.Controls.Toolbars.Drawing"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SnipShot">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid KeyboardAcceleratorPlacementMode="Hidden">
        <!-- Title Bar personalizada -->
        <Grid x:Name="AppTitleBar" 
              Height="48" 
              VerticalAlignment="Top"
              Canvas.ZIndex="1"
              Background="Transparent">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Icono y Título de la aplicación -->
            <StackPanel Grid.Column="0" 
                       Orientation="Horizontal" 
                       Spacing="12"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center">
                <Image Source="/Assets/Square44x44Logo.png" 
                       Width="16" 
                       Height="16"/>
                <TextBlock Text="SnipShot" 
                          FontSize="12"
                          VerticalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
            
            <!-- Área de arrastre (drag region) -->
            <Border Grid.Column="1" Background="Transparent"/>
        </Grid>
    
        <muxc:TeachingTip x:Name="WindowCaptureTeachingTip"
              Title="Captura de ventana"
              Subtitle="No hay ventanas disponibles para capturar."
              PreferredPlacement="Bottom"
              IsOpen="False"
              ShouldConstrainToRootBounds="False"
              CloseButtonContent="Entendido"
              IsLightDismissEnabled="True"
              Target="{Binding ElementName=NewCaptureButton}"/>

        <!-- InfoBar para notificación de búsqueda de imagen -->
        <muxc:InfoBar x:Name="SearchImageInfoBar"
                      Title="Imagen copiada"
                      Message="Pégala en el buscador usando Ctrl+V"
                      Severity="Informational"
                      IsOpen="False"
                      IsClosable="True"
                      VerticalAlignment="Bottom"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20"
                      Canvas.ZIndex="100"/>
        
        <!-- Panel Principal con margen superior para la Title Bar -->
        <Grid x:Name="MainPanel" Margin="0,30,0,0" SizeChanged="MainPanel_SizeChanged">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="BottomToolbarRow" Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra superior con botones -->
        <Grid Grid.Row="0" Padding="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Botones de captura a la izquierda -->
            <StackPanel x:Name="CaptureButtonsPanel" Grid.Column="0" 
                       Orientation="Horizontal" 
                       Spacing="10"
                       VerticalAlignment="Center">
                <Button x:Name="NewCaptureButton"
                       Click="NewCaptureButton_Click"
                       Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="16"/>
                        <TextBlock Text="Nueva Captura"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="CaptureOptionsButton"
                       ToolTipService.ToolTip="Captura Rectangular"
                       Background="Transparent"
                       BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon x:Name="CaptureOptionIcon" Glyph="&#xF407;" FontSize="16"/>
                        <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuFlyoutItem Text="Captura Rectangular" 
                                          Click="RectangularCapture_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xF407;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            
                            <MenuFlyoutItem Text="Captura de Ventana" 
                                          Click="WindowCapture_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xF7ED;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            
                            <MenuFlyoutItem Text="Pantalla Completa" 
                                          Click="FullScreenCapture_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE9A6;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            
                            <MenuFlyoutItem Text="Forma Libre" 
                                          Click="FreeFormCapture_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xF408;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button x:Name="DelayOptionsButton"
                       ToolTipService.ToolTip="Sin delay"
                       Background="Transparent"
                       BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon x:Name="DelayOptionIcon" Glyph="&#xE916;" FontSize="16"/>
                        <TextBlock x:Name="DelayOptionText" Text="0s"/>
                        <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuFlyoutItem Text="Sin delay" 
                                          Click="NoDelay_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE916;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            
                            <MenuFlyoutItem Text="3 segundos" 
                                          Click="Delay3_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE916;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            
                            <MenuFlyoutItem Text="5 segundos" 
                                          Click="Delay5_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE916;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            
                            <MenuFlyoutItem Text="10 segundos" 
                                          Click="Delay10_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE916;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <!-- Barra de herramientas de edición centrada (visible solo cuando hay imagen) -->
            <StackPanel x:Name="EditToolbar"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="4"
                        Visibility="Collapsed">
                
                <!-- Botón Formas -->
                <Button x:Name="EditShapesButton"
                        Click="EditShapesButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Formas">
                    <FontIcon Glyph="&#xF158;" FontSize="16"/>
                </Button>
                
                <!-- Botón Bolígrafo -->
                <Button x:Name="EditPenButton"
                        Click="EditPenButton_Click"
                        RightTapped="EditPenButton_RightTapped"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Bolígrafo">
                    <FontIcon x:Name="EditPenIcon" Glyph="&#xE76D;" FontSize="16"/>
                    <Button.Flyout>
                        <Flyout x:Name="EditPenFlyout" Placement="Bottom">
                            <drawing:PenToolbarControl x:Name="EditPenFlyoutToolbar"
                                                        ColorChanged="EditPenToolbar_ColorChanged"
                                                        ThicknessChanged="EditPenToolbar_ThicknessChanged"/>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                
                <!-- Botón Resaltador -->
                <Button x:Name="EditHighlighterButton"
                        Click="EditHighlighterButton_Click"
                        RightTapped="EditHighlighterButton_RightTapped"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Resaltador">
                    <FontIcon x:Name="EditHighlighterIcon" Glyph="&#xE7E6;" FontSize="16"/>
                    <Button.Flyout>
                        <Flyout x:Name="EditHighlighterFlyout" Placement="Bottom">
                            <drawing:HighlighterToolbarControl x:Name="EditHighlighterFlyoutToolbar"
                                                                ColorChanged="EditHighlighterToolbar_ColorChanged"
                                                                ThicknessChanged="EditHighlighterToolbar_ThicknessChanged"/>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                
                <!-- Boton Borrador -->
                <Button x:Name="EditEraserButton"
                        Click="EditEraserButton_Click"
                        RightTapped="EditEraserButton_RightTapped"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Borrador">
                    <FontIcon Glyph="&#xE75C;" FontSize="16"/>
                    <Button.Flyout>
                        <MenuFlyout x:Name="EditEraserFlyout" Placement="Bottom">
                            <MenuFlyoutItem Text="Limpiar todo"
                                            Click="EditClearAnnotations_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <!-- Botón Emoji -->
                <Button x:Name="EditEmojiButton"
                        Click="EditEmojiButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Emoji">
                    <FontIcon Glyph="&#xE76E;" FontSize="16"/>
                </Button>
                
                <!-- Botón Texto -->
                <Button x:Name="EditTextButton"
                        Click="EditTextButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Añadir texto">
                    <FontIcon Glyph="&#xE8D2;" FontSize="16"/>
                </Button>
                
                <!-- Separador -->
                <Border x:Name="EditToolbarSeparator"
                        Width="1"
                        Height="20"
                        Margin="6,0"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                
                <!-- Boton Recortar -->
                <Button x:Name="EditCropButton"
                        Click="EditCropButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Recortar">
                    <FontIcon Glyph="&#xE7A8;" FontSize="16"/>
                </Button>

                <!-- Boton Extraer texto -->
                <Button x:Name="EditOcrButton"
                        Click="EditOcrButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Extraer texto">
                    <Grid>
                        <FontIcon x:Name="EditOcrIcon" Glyph="&#xF683;" FontSize="16"/>
                        <ProgressRing x:Name="EditOcrProgressRing" 
                                      IsActive="False" 
                                      Visibility="Collapsed" 
                                      Width="16" Height="16"/>
                    </Grid>
                    <Button.Flyout>
                        <Flyout x:Name="EditOcrFlyout" 
                                Placement="Bottom"
                                ShouldConstrainToRootBounds="False"
                                Opened="EditOcrFlyout_Opened"
                                Closed="EditOcrFlyout_Closed">
                            <StackPanel Spacing="0" MinWidth="180" Margin="-11">
                                <Button x:Name="EditOcrCopyAllButton"
                                        Click="EditOcrCopyAll_Click"
                                        IsEnabled="False"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon x:Name="EditOcrCopyAllIcon" Glyph="&#xE8C8;" FontSize="16"/>
                                        <TextBlock Text="Copiar todo el texto" VerticalAlignment="Center" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Boton Aplicar recorte -->
                <Button x:Name="CropApplyButton"
                        Click="CropApplyButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Aplicar recorte">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73E;" FontSize="16"/>
                        <TextBlock Text="Aplicar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Boton Cancelar recorte -->
                <Button x:Name="CropCancelButton"
                        Click="CropCancelButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Cancelar recorte">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE711;" FontSize="16"/>
                        <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Botón Deshacer -->
                <Button x:Name="EditUndoButton"
                        Click="EditUndoButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Deshacer (Ctrl+Z)">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Z"/>
                    </Button.KeyboardAccelerators>
                    <FontIcon Glyph="&#xE7A7;" FontSize="16"/>
                </Button>
                
                <!-- Botón Rehacer -->
                <Button x:Name="EditRedoButton"
                        Click="EditRedoButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        CornerRadius="4"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Rehacer (Ctrl+Y)">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Y"/>
                    </Button.KeyboardAccelerators>
                    <FontIcon Glyph="&#xE7A6;" FontSize="16"/>
                </Button>
            </StackPanel>

            <!-- Botones de acción y More a la derecha -->
            <StackPanel x:Name="ActionButtonsPanel" Grid.Column="2" 
                       Orientation="Horizontal" 
                       Spacing="2"
                       VerticalAlignment="Center">
                <!-- Botones de acción (visibles solo cuando hay captura) -->
                <Button x:Name="CopyButton"
                       Click="CopyButton_Click"
                       Visibility="Collapsed"
                       Background="Transparent"
                       BorderBrush="Transparent"
                       ToolTipService.ToolTip="Copiar">
                    <FontIcon x:Name="CopyButtonIcon" Glyph="&#xE8C8;" FontSize="16"/>
                </Button>
                
                <Button x:Name="SaveButton"
                       Click="SaveButton_Click"
                       Visibility="Collapsed"
                       Background="Transparent"
                       BorderBrush="Transparent"
                       ToolTipService.ToolTip="Guardar">
                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                </Button>
                
                <Button x:Name="ClearButton"
                       Click="ClearButton_Click"
                       Visibility="Collapsed"
                       Background="Transparent"
                       BorderBrush="Transparent"
                       ToolTipService.ToolTip="Eliminar captura">
                    <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                </Button>

                <!-- Separador vertical -->
                <Border x:Name="ActionButtonsSeparator"
                        Width="1"
                        Height="20"
                        Margin="6,0"
                        Visibility="Collapsed"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <Button x:Name="MoreButton"
                       ToolTipService.ToolTip="Más opciones">
                    <FontIcon Glyph="&#xE712;" FontSize="16"/>
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuFlyoutItem Text="Abrir Imagen" 
                                          Click="OpenImageButton_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8E5;"/>
                                </MenuFlyoutItem.Icon>
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="Control" Key="O"/>
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>

                            <MenuFlyoutItem Text="Abrir carpeta de capturas"
                                          Click="OpenCapturesFolder_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B7;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            
                            <MenuFlyoutSubItem x:Name="ZoomSubmenu"
                                             Text="Zoom"
                                             Visibility="Collapsed">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE71E;"/>
                                </MenuFlyoutSubItem.Icon>
                                
                                <MenuFlyoutItem Text="Acercar" 
                                              Click="ZoomIn_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A3;"/>
                                    </MenuFlyoutItem.Icon>
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Modifiers="Control" Key="Add"/>
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                
                                <MenuFlyoutItem Text="Alejar" 
                                              Click="ZoomOut_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE71F;"/>
                                    </MenuFlyoutItem.Icon>
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Modifiers="Control" Key="Subtract"/>
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                
                                <MenuFlyoutItem Text="Tamaño real" 
                                              Click="ZoomActualSize_Click">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Modifiers="Control" Key="Number0"/>
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                
                                <MenuFlyoutItem Text="Ajustar a ventana" 
                                              Click="ZoomFit_Click">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Modifiers="Control,Shift" Key="Number0"/>
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                
                                <MenuFlyoutSeparator/>
                                
                                <MenuFlyoutItem x:Name="ZoomLevelMenuItem">
                                    <MenuFlyoutItem.Template>
                                        <ControlTemplate>
                                            <TextBlock x:Name="ZoomLevelText"
                                                      Text="100%"
                                                      FontWeight="SemiBold"
                                                      HorizontalAlignment="Center"
                                                      Margin="12,8"/>
                                        </ControlTemplate>
                                    </MenuFlyoutItem.Template>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>
                            
                            <MenuFlyoutItem Text="Configuración" 
                                          Click="SettingsButton_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE713;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>
        
        <!-- Separador debajo de los botones -->
        <Border Grid.Row="0" 
                Height="1" 
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                VerticalAlignment="Bottom"/>

        <!-- Área central para vista previa y edición -->
        <Grid Grid.Row="1" Padding="20,10" KeyDown="MainGrid_KeyDown"
              KeyboardAcceleratorPlacementMode="Hidden">
            <Grid.KeyboardAccelerators>
                <KeyboardAccelerator Key="Escape" Invoked="MainGrid_EscapeInvoked"/>
            </Grid.KeyboardAccelerators>
            <Border x:Name="PreviewBorder"
                   Background="Transparent"
                   BorderBrush="Transparent"
                   BorderThickness="0"
                   CornerRadius="8">
                
                <Grid>
                    <!-- Placeholder cuando no hay captura -->
                    <StackPanel x:Name="PlaceholderPanel"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Spacing="12"
                               MaxWidth="400">
                        <TextBlock Text="SnipShot"
                                  FontSize="32"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"/>
                        <TextBlock HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0">
                            <Run Text="Presiona " Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="13"/>
                            <Run Text="Ctrl+Shift+S" FontWeight="SemiBold" FontSize="13"/>
                            <Run Text=" o haz clic en " Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="13"/>
                            <Run Text="Nueva Captura" FontWeight="SemiBold" FontSize="13"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Control de edición de imagen (incluye la imagen y canvas de anotaciones) -->
                    <controls:ImageEditorControl x:Name="ImageEditor"
                                                 KeyboardAcceleratorPlacementMode="Hidden"
                                                 Visibility="Collapsed"
                                                 UndoRedoStateChanged="ImageEditor_UndoRedoStateChanged"
                                                 ImageModified="ImageEditor_ImageModified"
                                                 SaveImageRequested="ImageEditor_SaveImageRequested"
                                                 CopyImageRequested="ImageEditor_CopyImageRequested"
                                                 SearchImageRequested="ImageEditor_SearchImageRequested"/>

                    <!-- Mantener ScrollViewer y PreviewImage para compatibilidad (ocultos) -->
                    <ScrollViewer x:Name="PreviewScrollViewer"
                                  Visibility="Collapsed"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="Transparent"
                                  ZoomMode="Enabled"
                                  MinZoomFactor="0.1"
                                  MaxZoomFactor="10.0">
                        <Grid x:Name="ImageContainer"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Image x:Name="PreviewImage"
                                   Stretch="None"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Barra de herramientas inferior (visible solo en modo compacto) -->
        <Grid x:Name="BottomToolbarPanel" 
              Grid.Row="2" 
              Visibility="Collapsed"
              Padding="20,10,20,20">
            
            <!-- Separador superior -->
            <Border Height="1" 
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    VerticalAlignment="Top"
                    Margin="-20,0,-20,0"/>
            
            <!-- Contenedor para el EditToolbar cuando se mueve abajo -->
            <Border x:Name="BottomToolbarContainer"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,10,0,0"/>
        </Grid>

        </Grid>

        <!-- Panel de Configuración con margen superior -->
        <views:SettingsView x:Name="SettingsView" 
                           Margin="0,48,0,0"
                           Visibility="Collapsed"/>
    </Grid>
</Window>













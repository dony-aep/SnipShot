<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="SnipShot.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnipShot">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Recursos temáticos para Overlays -->
            <ResourceDictionary.ThemeDictionaries>
                <!-- Tema Claro -->
                <ResourceDictionary x:Key="Light">
                    <!-- Fondo semi-transparente para menús flotantes (gris claro con opacidad) -->
                    <SolidColorBrush x:Key="OverlayMenuBackgroundBrush" Color="#DDF5F5F5"/>
                    
                    <!-- Bordes para overlays (negro en tema claro) -->
                    <SolidColorBrush x:Key="OverlayBorderBrush" Color="#FF000000"/>
                    
                    <!-- Texto principal en overlays (negro) -->
                    <SolidColorBrush x:Key="OverlayTextBrush" Color="#FF000000"/>
                    
                    <!-- Texto secundario en overlays (gris oscuro) -->
                    <SolidColorBrush x:Key="OverlayTextSecondaryBrush" Color="#FF666666"/>
                </ResourceDictionary>
                
                <!-- Tema Oscuro -->
                <ResourceDictionary x:Key="Dark">
                    <!-- Fondo semi-transparente para menús flotantes (gris oscuro con opacidad) -->
                    <SolidColorBrush x:Key="OverlayMenuBackgroundBrush" Color="#DD1E1E1E"/>
                    
                    <!-- Bordes para overlays (blanco en tema oscuro) -->
                    <SolidColorBrush x:Key="OverlayBorderBrush" Color="#FFFFFFFF"/>
                    
                    <!-- Texto principal en overlays (blanco) -->
                    <SolidColorBrush x:Key="OverlayTextBrush" Color="#FFFFFFFF"/>
                    
                    <!-- Texto secundario en overlays (gris claro) -->
                    <SolidColorBrush x:Key="OverlayTextSecondaryBrush" Color="#FFAAAAAA"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            
            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>

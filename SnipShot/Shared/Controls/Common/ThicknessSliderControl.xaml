<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SnipShot.Shared.Controls.Common.ThicknessSliderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnipShot.Shared.Controls.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <TextBlock x:Name="TitleText" Text="Tamaño" FontWeight="SemiBold"/>
        <Border Height="48"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="6">
            <Rectangle x:Name="ThicknessPreview"
                       Width="120"
                       Height="2"
                       Fill="Black"
                       RadiusX="1" RadiusY="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
        <Slider x:Name="ThicknessSlider"
                Minimum="1"
                Maximum="12"
                Value="2"
                StepFrequency="1"
                ValueChanged="ThicknessSlider_ValueChanged"/>
    </StackPanel>
</UserControl>

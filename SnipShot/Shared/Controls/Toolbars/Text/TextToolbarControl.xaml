<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SnipShot.Shared.Controls.Toolbars.Text.TextToolbarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnipShot.Shared.Controls.Toolbars.Text"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8"
            Translation="0,0,32"
            Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
        <Border.Shadow>
            <ThemeShadow/>
        </Border.Shadow>
        <StackPanel Spacing="8">
            <!-- Vista Previa del Texto -->
            <Border x:Name="TextPreviewBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,8"
                    MinHeight="50"
                    MaxHeight="100"
                    HorizontalAlignment="Stretch">
                <Border x:Name="TextPreviewHighlightBorder"
                        Background="Transparent"
                        CornerRadius="2"
                        Padding="4,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="TextPreviewBlock"
                               Text="Texto de ejemplo"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               Foreground="White"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="500"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Border>
            
            <!-- Controles de formato -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- Selector de Fuente -->
                <ComboBox x:Name="FontFamilyComboBox"
                          Width="140"
                          Height="36"
                          VerticalAlignment="Center"
                          SelectionChanged="FontFamilyComboBox_SelectionChanged"
                          ToolTipService.ToolTip="Fuente">
                    <ComboBoxItem Content="Segoe UI" IsSelected="True"/>
                    <ComboBoxItem Content="Arial"/>
                    <ComboBoxItem Content="Times New Roman"/>
                    <ComboBoxItem Content="Calibri"/>
                    <ComboBoxItem Content="Consolas"/>
                    <ComboBoxItem Content="Comic Sans MS"/>
                    <ComboBoxItem Content="Georgia"/>
                    <ComboBoxItem Content="Verdana"/>
                    <ComboBoxItem Content="Tahoma"/>
                </ComboBox>

                <!-- Selector de Tamaño (Editable) -->
                <ComboBox x:Name="FontSizeComboBox"
                          IsEditable="True"
                          Width="75"
                          Height="36"
                          VerticalAlignment="Center"
                          Text="16"
                          TextSubmitted="FontSizeComboBox_TextSubmitted"
                          SelectionChanged="FontSizeComboBox_SelectionChanged"
                          ToolTipService.ToolTip="Tamaño de fuente">
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="9"/>
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="11"/>
                    <ComboBoxItem Content="12"/>
                    <ComboBoxItem Content="14"/>
                    <ComboBoxItem Content="16" IsSelected="True"/>
                    <ComboBoxItem Content="18"/>
                    <ComboBoxItem Content="20"/>
                    <ComboBoxItem Content="24"/>
                    <ComboBoxItem Content="28"/>
                    <ComboBoxItem Content="32"/>
                    <ComboBoxItem Content="36"/>
                    <ComboBoxItem Content="48"/>
                    <ComboBoxItem Content="56"/>
                    <ComboBoxItem Content="72"/>
                </ComboBox>

                <Border Width="1" 
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Margin="4,6"/>

                <!-- Estilos de texto -->
                <ToggleButton x:Name="BoldToggle"
                              Click="BoldToggle_Click"
                              Width="36" Height="36"
                              Padding="0"
                              CornerRadius="4"
                              ToolTipService.ToolTip="Negrita (Ctrl+B)">
                    <FontIcon Glyph="&#xE8DD;" FontSize="14"/>
                </ToggleButton>
                <ToggleButton x:Name="ItalicToggle"
                              Click="ItalicToggle_Click"
                              Width="36" Height="36"
                              Padding="0"
                              CornerRadius="4"
                              ToolTipService.ToolTip="Cursiva (Ctrl+I)">
                    <FontIcon Glyph="&#xE8DB;" FontSize="14"/>
                </ToggleButton>
                <ToggleButton x:Name="UnderlineToggle"
                              Click="UnderlineToggle_Click"
                              Width="36" Height="36"
                              Padding="0"
                              CornerRadius="4"
                              ToolTipService.ToolTip="Subrayado (Ctrl+U)">
                    <FontIcon Glyph="&#xE8DC;" FontSize="14"/>
                </ToggleButton>
                <ToggleButton x:Name="StrikethroughToggle"
                              Click="StrikethroughToggle_Click"
                              Width="36" Height="36"
                              Padding="0"
                              CornerRadius="4"
                              ToolTipService.ToolTip="Tachado">
                    <FontIcon Glyph="&#xEDE0;" FontSize="14"/>
                </ToggleButton>

                <Border Width="1" 
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Margin="4,6"/>

                <!-- Botón Color de Texto -->
                <Button x:Name="TextColorButton"
                        Click="TextColorButton_Click"
                        Width="36" Height="36"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Color del texto">
                    <Grid>
                        <FontIcon Glyph="&#xE8D3;" FontSize="14" Margin="0,-2,0,0"/>
                        <Border x:Name="TextColorIndicator"
                                Height="4"
                                Width="16"
                                Background="White"
                                CornerRadius="1"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,4"/>
                    </Grid>
                </Button>

                <!-- Botón Color de Resaltado -->
                <Button x:Name="TextHighlightButton"
                        Click="TextHighlightButton_Click"
                        Width="36" Height="36"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Color de resaltado">
                    <Grid>
                        <FontIcon Glyph="&#xE7E6;" FontSize="14" Margin="0,-2,0,0"/>
                        <Border x:Name="TextHighlightIndicator"
                                Height="4"
                                Width="16"
                                Background="Transparent"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="1"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,4"/>
                    </Grid>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

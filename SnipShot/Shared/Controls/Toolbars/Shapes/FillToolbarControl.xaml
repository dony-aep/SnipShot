<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SnipShot.Shared.Controls.Toolbars.Shapes.FillToolbarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnipShot.Shared.Controls.Toolbars.Shapes"
    xmlns:common="using:SnipShot.Shared.Controls.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Vertical" Spacing="14" MinWidth="220">
            <!-- Sección de color de relleno -->
            <common:ColorPaletteControl x:Name="ColorPalette"
                                       PaletteType="Standard"
                                       Title="Color de relleno"
                                       ColorSelected="ColorPalette_ColorSelected"/>

            <!-- Sección de opacidad del relleno -->
            <StackPanel Spacing="6">
                <TextBlock Text="Opacidad del relleno" FontWeight="SemiBold"/>
                <Slider x:Name="OpacitySlider"
                        Minimum="0"
                        Maximum="100"
                        Value="0"
                        StepFrequency="1"
                        ValueChanged="OpacitySlider_ValueChanged"/>
        </StackPanel>
    </StackPanel>
</UserControl>

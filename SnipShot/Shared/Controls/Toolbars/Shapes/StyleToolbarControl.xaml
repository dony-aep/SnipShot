<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SnipShot.Shared.Controls.Toolbars.Shapes.StyleToolbarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnipShot.Shared.Controls.Toolbars.Shapes"
    xmlns:common="using:SnipShot.Shared.Controls.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Vertical" Spacing="14" MinWidth="220">
            <!-- Sección de color -->
            <common:ColorPaletteControl x:Name="ColorPalette"
                                       PaletteType="Standard"
                                       Title="Color"
                                       ColorSelected="ColorPalette_ColorSelected"/>

            <!-- Sección de opacidad -->
            <StackPanel Spacing="6">
                <TextBlock Text="Opacidad" FontWeight="SemiBold"/>
                <Slider x:Name="OpacitySlider"
                        Minimum="0"
                        Maximum="100"
                        Value="100"
                        StepFrequency="1"
                        ValueChanged="OpacitySlider_ValueChanged"/>
            </StackPanel>

            <!-- Sección de tamaño -->
            <StackPanel Spacing="8">
                <TextBlock Text="Tamaño del trazo" FontWeight="SemiBold"/>
                <Border Height="48"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        CornerRadius="6">
                    <Rectangle x:Name="ThicknessPreview"
                               Width="120"
                               Height="3"
                               Fill="Red"
                               RadiusX="2" RadiusY="2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <Slider x:Name="ThicknessSlider"
                        Minimum="1"
                        Maximum="32"
                        Value="3"
                        StepFrequency="1"
                        ValueChanged="ThicknessSlider_ValueChanged"/>
        </StackPanel>
    </StackPanel>
</UserControl>

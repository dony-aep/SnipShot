<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SnipShot.Shared.Controls.Toolbars.Emoji.EmojiToolbarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnipShot.Shared.Controls.Toolbars.Emoji"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Vertical" Spacing="8">
        <!-- Category Buttons -->
        <StackPanel x:Name="CategoryPanel" Orientation="Horizontal" Spacing="2">
            <Button x:Name="SmileysCategory"
                    Click="CategoryButton_Click"
                    Tag="smileys"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    CornerRadius="4"
                    Width="36" Height="36"
                    FontSize="18"
                    Content="😀"
                    ToolTipService.ToolTip="Caritas"/>
            <Button x:Name="GesturesCategory"
                    Click="CategoryButton_Click"
                    Tag="gestures"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    CornerRadius="4"
                    Width="36" Height="36"
                    FontSize="18"
                    Content="👍"
                    ToolTipService.ToolTip="Gestos"/>
            <Button x:Name="SymbolsCategory"
                    Click="CategoryButton_Click"
                    Tag="symbols"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    CornerRadius="4"
                    Width="36" Height="36"
                    FontSize="18"
                    Content="❤️"
                    ToolTipService.ToolTip="Símbolos"/>
            <Button x:Name="CelebrationCategory"
                    Click="CategoryButton_Click"
                    Tag="celebration"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    CornerRadius="4"
                    Width="36" Height="36"
                    FontSize="18"
                    Content="🎉"
                    ToolTipService.ToolTip="Celebración"/>
            <Button x:Name="NatureCategory"
                    Click="CategoryButton_Click"
                    Tag="nature"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    CornerRadius="4"
                    Width="36" Height="36"
                    FontSize="18"
                    Content="🌸"
                    ToolTipService.ToolTip="Naturaleza"/>
            <Button x:Name="ArrowsCategory"
                    Click="CategoryButton_Click"
                    Tag="arrows"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    CornerRadius="4"
                    Width="36" Height="36"
                    FontSize="18"
                    Content="➡️"
                    ToolTipService.ToolTip="Flechas"/>
        </StackPanel>

        <!-- Emoji Grid -->
        <ScrollViewer x:Name="EmojiScrollViewer"
                      MaxHeight="180"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EmojiGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" 
                                       ItemWidth="40" 
                                       ItemHeight="40"
                                       MaximumRowsOrColumns="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Button Content="{x:Bind}"
                                Click="EmojiButton_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Width="36" Height="36"
                                FontSize="22"
                                FontFamily="Segoe UI Emoji"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                CornerRadius="4">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#20FFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#40FFFFFF"/>
                            </Button.Resources>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
